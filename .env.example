# secret key for patient pseudonymization
REFINERY_NODE_SECRET=secret-key

# epsilon for differential privacy
REFINERY_EPSILON=0.5

# minimum cohort size for differential privacy
REFINERY_MIN_COHORT=25

# total budget for differential privacy
REFINERY_TOTAL_BUDGET=10.0

# minimum number of participating nodes required for SMPC federation
REFINERY_MIN_PARTICIPATING_NODES=3

# optional orchestrator ledger path
REFINERY_ORCHESTRATOR_DB=data/orchestrator.duckdb

# node SMPC private key as 32-byte hex
# required for `refinery-node serve` to advertise SMPC capability and accept federated jobs
# Examples:
# af717e5dc57e048a45d733447b3c78383594c86bb4f42ece4926c781a93eeaa6
# eaaf1b46b4a42c495b198ad4ee6b0890fd618ac4b05c04956cb393686a239b58
# df6a8fbb6e9630f4df5ec9c92a11daec093f35bb4385b7eb26f123a39ea0c906
REFINERY_SMPC_PRIVATE_KEY_HEX=replace-with-64-hex-characters

# output format for CLI commands
REFINERY_CLI_OUTPUT=plain|pretty